@model IEnumerable<CoffeeWeb.Models.EF.ProductCategory>

@if (Model != null && Model.Any())
{
    <section class="product-category-top py-3">
        <div class="container">

            <div class="row justify-content-center text-center">
                @foreach (var item in Model)
                {
                    <div class="col-md-3 col-sm-4 col-6 mb-3">
                        <a href="/product_category/@item.Alias-@(item.Id)"
                           class="d-block py-2 px-3 border rounded text-dark font-weight-bold
                                  text-decoration-none bg-light category-item">
                            @item.Title
                        </a>
                    </div>
                }
            </div>

        </div>
    </section>
}
