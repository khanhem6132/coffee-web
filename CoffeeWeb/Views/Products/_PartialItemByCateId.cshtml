@model IEnumerable<CoffeeWeb.Models.EF.Product>
@if (Model != null && Model.Any())
{
    foreach (var item in Model)
    {
        
        var strImg = "";
        var img = item.ProductImage.FirstOrDefault(x => x.IsDefault);
        if(img!=null)
        {
            strImg = img.Image;
        }
        <div class="product-item @item.ProductCategory.Alias">
            <div class="product discount product_filter">
                <div class="product_image">
                    <img src="@strImg" alt="@item.Title'">
                </div>
                <div class="favorite favorite_left"></div>
                <div class="product_bubble product_bubble_right product_bubble_red d-flex flex-column align-items-center"><span>New</span></div>
                <div class="product_info">
                    <h6 class="product_name"><a href="/detail/@item.Alias-p@(item.Id)">@item.Title</a></h6>
                    @if (item.PriceSale > 0)
                    {
                        <div class="product_price">@item.PriceSale.GetValueOrDefault().ToString("#,##0") VND<span>@item.Price.ToString("#,##0") VND</span></div>
                    }
                    else
                    {
                        <div class="product_price">@item.Price.ToString("#,##0") VND</div>
                    }

                </div>
            </div>
            <div class="red_button add_to_cart_button"><a href="#" class="btnAddToCart" data-id="@item.Id">add to cart</a></div>
        </div>
    }
}
