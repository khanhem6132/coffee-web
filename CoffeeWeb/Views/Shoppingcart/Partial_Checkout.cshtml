@model CoffeeWeb.Models.OrderViewModel

@using (Html.BeginForm("CheckOut", "ShoppingCart", FormMethod.Post, new { id = "myForm" }))
{
    @Html.AntiForgeryToken()

    <h3>Customer Information</h3>

    <div class="form-group">
        <label>Full Name</label>
        <input type="text"
               name="CustomerName"
               required
               class="form-control inputcheckout"
               autocomplete="off" />
    </div>

    <div class="form-group">
        <label>Phone Number</label>
        <input type="text"
               name="Phone"
               class="form-control inputcheckout"
               autocomplete="off" />
    </div>

    <div class="form-group">
        <label>Address</label>
        <input type="text"
               name="Address"
               class="form-control inputcheckout"
               autocomplete="off" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input type="email"
               name="Email"
               class="form-control inputcheckout"
               autocomplete="off" />
    </div>

    <div class="form-group">
        <label>Payment Method</label>
        <select class="form-control" name="TypePayment">
            <option value="1" selected>Cash on Delivery (COD)</option>
            <option value="2">Bank Card</option>
        </select>
    </div>

    <div class="form-group">
        <button type="submit" class="btn btn-block btn-success">
            Place Order
        </button>
    </div>
}
