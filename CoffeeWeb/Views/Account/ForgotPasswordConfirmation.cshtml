@{
    ViewBag.Title = "Xác nhận quên mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container" style="margin-top:160px; margin-bottom:100px">
    <main aria-labelledby="title" class="col-lg-6 offset-lg-3 col-md-8 offset-md-2">

        <div class="card shadow-lg border-0 rounded-3">
            <div class="card-body p-4">

                <h2 id="title" class="text-center mb-4">@ViewBag.Title</h2>

                <div class="text-center">
                    <h5 class="mb-4 text-success">
                        Yêu cầu đặt lại mật khẩu thành công
                    </h5>

                    <p class="lead mb-4">
                        Vui lòng kiểm tra email của bạn để đặt lại mật khẩu.
                    </p>

                    <div class="form-group text-center mt-4">
                        @Html.ActionLink("Quay lại đăng nhập", "Login", "Account", null, new { @class = "btn btn-outline-dark w-100" })
                    </div>
                </div>

                <div class="text-center mt-3">
                    @Html.ActionLink("← Quay lại trang chủ", "Index", "Home", null, new { @class = "text-decoration-none text-secondary" })
                </div>

            </div>
        </div>
    </main>
</div>

@section Scripts {
}