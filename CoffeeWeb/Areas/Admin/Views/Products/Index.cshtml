@model PagedList.PagedList<CoffeeWeb.Models.EF.Product>
@using PagedList;
@using PagedList.Mvc;
@{
    ViewBag.Title = "Product List";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="content">

    <div class="card">
        <div class="card-header">
            <h3 class="card-title">@ViewBag.Title</h3>
            <div class="card-tools">
                <a href="/admin/products/add" class="btn btn-primary">Add New</a>
                <a href="#" class="btn btn-danger" id="btnDeleteAll">Delete</a>
            </div>
        </div>

        <div class="card-body">
            <div class="col-6">
                @using (Html.BeginForm("Index", "Products", FormMethod.Get, new { }))
                {
                    <div class="input-group input-group-sm">
                        @Html.TextBox("searchText", null, new { @class = "form-control" })
                        <span class="input-group-append">
                            <button type="submit" class="btn btn-info btn-flat">Search</button>
                        </span>
                    </div>
                }
            </div>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="SelectAll" /></th>
                        <th>No.</th>
                        <th>Image</th>
                        <th>Product Name</th>
                        <th>Category</th>
                        <th>Quantity</th>
                        <th>Price</th>
                        <th>Created Date</th>
                        <th class="text-center">Home</th>
                        <th class="text-center">On Sale</th>
                        <th class="text-center">Active</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var i = ((ViewBag.Page - 1) * ViewBag.PageSize) + 1;
                        foreach (var item in Model)
                        {
                            var strCheck = item.IsActive ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>";
                            var strCheckHome = item.IsHome ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>";
                            var strCheckSale = item.IsSale ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>";

                            <tr id="trow_@item.Id">
                                <td><input type="checkbox" class="cbkItem" value="@item.Id" /></td>
                                <td>@i</td>
                                <td>
                                    <img src="@(item.ProductImage?.FirstOrDefault(x => x.IsDefault)?.Image)" width="50" />
                                </td>
                                <td>@item.Title</td>
                                <td>@item.ProductCategory.Title</td>
                                <td>@item.Quantity</td>
                                <td>@item.Price.ToString("#,##0") VND</td>
                                <td>@item.CreateDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-center">
                                    <a href="#" data-id="@item.Id" class="btnHome">@Html.Raw(strCheckHome)</a>
                                </td>
                                <td class="text-center">
                                    <a href="#" data-id="@item.Id" class="btnSale">@Html.Raw(strCheckSale)</a>
                                </td>
                                <td class="text-center">
                                    <a href="#" data-id="@item.Id" class="btnActive">@Html.Raw(strCheck)</a>
                                </td>
                                <td>
                                    <a href="/admin/products/edit/@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a href="#" data-id="@item.Id" class="btn btn-sm btn-danger btnDelete">Delete</a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4">No records found</td>
                        </tr>
                    }
            </table>

            <div class="row">
                <div class="col-6"></div>
                <div class="col-6" style="text-align:right">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page }))
                </div>
            </div>
        </div>

        <div class="card-footer"></div>
    </div>

</section>

@section scripts{
    <script>
        $(document).ready(function () {

            $('body').on('click', '#btnDeleteAll', function (e) {
                e.preventDefault();
                var str = "";
                var checkbox = $(this).parents('.card').find('tr td input:checkbox');
                var i = 0;

                checkbox.each(function () {
                    if (this.checked) {
                        checkbox.attr('selected', 'checked');
                        var _id = $(this).val();
                        if (i == 0) str += _id;
                        else str += "," + _id;
                        i++;
                    } else {
                        checkbox.attr('selected', '');
                    }
                });

                if (str.length > 0) {
                    var conf = confirm('Do you want to delete these records?');
                    if (conf == true) {
                        $.ajax({
                            url: '/admin/products/deleteAll',
                            type: 'POST',
                            data: { ids: str },
                            success: function (rs) {
                                if (rs.success) {
                                    location.reload();
                                }
                            }
                        });
                    }
                }
            });

            $('body').on('change', '#SelectAll', function () {
                var checkStatus = this.checked;
                var checkbox = $(this).parents('.card-body').find('tr td input:checkbox');
                checkbox.each(function () {
                    this.checked = checkStatus;
                    if (this.checked) checkbox.attr('selected', 'checked');
                    else checkbox.attr('selected', '');
                });
            });

            $('body').on('click', '.btnDelete', function (e) {
                e.preventDefault();
                var id = $(this).data("id");
                var conf = confirm("Do you want to delete this record?");
                if (conf == true) {
                    $.ajax({
                        url: '/admin/products/delete',
                        type: 'POST',
                        data: { id: id },
                        success: function (rs) {
                            if (rs.success) {
                                $('#trow_' + id).remove();
                                location.reload();
                            }
                        }
                    })
                }
            });

            $('body').on('click', '.btnActive', function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data("id");
                $.ajax({
                    url: '/admin/products/IsActive',
                    type: 'POST',
                    data: { id: id },
                    success: function (rs) {
                        if (rs.success) {
                            btn.html(rs.isActive ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>");
                        }
                    }
                });
            });

            $('body').on('click', '.btnHome', function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data("id");
                $.ajax({
                    url: '/admin/products/IsHome',
                    type: 'POST',
                    data: { id: id },
                    success: function (rs) {
                        if (rs.success) {
                            btn.html(rs.isHome ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>");
                        }
                    }
                });
            });

            $('body').on('click', '.btnSale', function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data("id");
                $.ajax({
                    url: '/admin/products/IsSale',
                    type: 'POST',
                    data: { id: id },
                    success: function (rs) {
                        if (rs.success) {
                            btn.html(rs.isSale ? "<i class='fa fa-check text-success' ></i>" : "<i class='fas fa-times text-danger' ></i>");
                        }
                    }
                });
            });

        });
    </script>
}
