@model PagedList.IPagedList<CoffeeWeb.Models.EF.Aboutus>
@using PagedList;
@using PagedList.Mvc;

@{
    ViewBag.Title = "About Us List";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<section class="content">
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">@ViewBag.Title</h3>
            <div class="card-tools">
                <a href="/admin/aboutus/add" class="btn btn-primary">Add New</a>
                <a href="#" class="btn btn-danger" id="btnDeleteAll">Delete</a>
            </div>
        </div>

        <div class="card-body">
            <div class="row mb-3">
                <div class="col-6">
                    @using (Html.BeginForm("Index", "Aboutus", FormMethod.Get))
                    {
                        <div class="input-group input-group-sm">
                            @Html.TextBox("searchText", Request["searchText"], new { @class = "form-control", placeholder = "Search..." })
                            <span class="input-group-append">
                                <button type="submit" class="btn btn-info btn-flat">Search</button>
                            </span>
                        </div>
                    }
                </div>
            </div>

            <table class="table table-hover">
                <thead>
                    <tr>
                        <th><input type="checkbox" id="SelectAll" /></th>
                        <th>No.</th>
                        <th>Image</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Created Date</th>
                        <th>Status</th>
                        <th style="width:160px;"></th>
                    </tr>
                </thead>

                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        var i = ((ViewBag.Page - 1) * ViewBag.PageSize) + 1;

                        foreach (var item in Model)
                        {
                            var strCheck = item.IsActive
                                ? "<i class='fa fa-check text-success'></i>"
                                : "<i class='fas fa-times text-danger'></i>";

                            <tr id="trow_@item.Id">
                                <td><input type="checkbox" class="cbkItem" value="@item.Id" /></td>
                                <td>@i</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.Image))
                                    {
                                        <img src="@item.Image" width="100" />
                                    }
                                </td>
                                <td>@item.Title</td>
                                <td>@(item.Category != null ? item.Category.Title : "")</td>
                                <td>@item.CreateDate.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <a href="#" data-id="@item.Id" class="btnActive">@Html.Raw(strCheck)</a>
                                </td>
                                <td>
                                    <a href="/admin/aboutus/edit/@item.Id" class="btn btn-sm btn-primary">Edit</a>
                                    <a href="#" data-id="@item.Id" class="btn btn-sm btn-danger btnDelete">Delete</a>
                                </td>
                            </tr>
                            i++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8">No records found</td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="row">
                <div class="col-6"></div>
                <div class="col-6" style="text-align:right">
                    @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchText = Request["searchText"] }))
                </div>
            </div>
        </div>

        <div class="card-footer"></div>
    </div>
</section>

@section scripts{
    <script>
        $(document).ready(function () {

            // Delete selected
            $('body').on('click', '#btnDeleteAll', function (e) {
                e.preventDefault();
                var str = "";
                var checkbox = $(this).parents('.card').find('tr td input:checkbox');
                var i = 0;

                checkbox.each(function () {
                    if (this.checked) {
                        var _id = $(this).val();
                        str += (i === 0) ? _id : ("," + _id);
                        i++;
                    }
                });

                if (str.length > 0) {
                    var conf = confirm('Do you want to delete these records?');
                    if (conf === true) {
                        $.ajax({
                            url: '/admin/aboutus/deleteAll',
                            type: 'POST',
                            data: { ids: str },
                            success: function (rs) {
                                if (rs.success) {
                                    location.reload();
                                }
                            }
                        });
                    }
                }
            });

            // Select all
            $('body').on('change', '#SelectAll', function () {
                var checkStatus = this.checked;
                var checkbox = $(this).parents('.card-body').find('tr td input:checkbox');
                checkbox.each(function () {
                    this.checked = checkStatus;
                });
            });

            // Delete one
            $('body').on('click', '.btnDelete', function () {
                var id = $(this).data("id");
                var conf = confirm("Do you want to delete this record?");
                if (conf === true) {
                    $.ajax({
                        url: '/admin/aboutus/delete',
                        type: 'POST',
                        data: { id: id },
                        success: function (rs) {
                            if (rs.success) {
                                $('#trow_' + id).remove();
                            }
                        }
                    });
                }
            });

            // Toggle IsActive
            $('body').on('click', '.btnActive', function (e) {
                e.preventDefault();
                var btn = $(this);
                var id = btn.data("id");

                $.ajax({
                    url: '/admin/aboutus/isactive',
                    type: 'POST',
                    data: { id: id },
                    success: function (rs) {
                        if (rs.success) {
                            if (rs.isActive) {
                                btn.html("<i class='fa fa-check text-success'></i>");
                            } else {
                                btn.html("<i class='fas fa-times text-danger'></i>");
                            }
                        }
                    }
                });
            });

        });
    </script>
}
